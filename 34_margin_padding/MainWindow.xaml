        <Button Grid.Row="0" Margin="20 10 20 10">Click me! 1</Button>
        <Button Grid.Row="1" Margin="20 10 20 10">Click me! 2</Button>
        <Button Grid.Row="2" Margin="20 10 20 10">Click me! 3</Button>

    </Grid>
