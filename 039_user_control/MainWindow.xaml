<Window x:Class="_039_user_control.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_039_user_control"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <DockPanel>
        <TextBlock DockPanel.Dock ="Top"
                   Text="Color Test"
                   FontSize="20"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="20 20 20 0"/>

        <StackPanel DockPanel.Dock ="Top"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Button Width="50"
                    Height="50"
                    Margin="20"
                    HorizontalAlignment="Center">

                <StackPanel>
                    <Rectangle Width="25"
                               Height="25"
                               Fill="Red"/>

                    <TextBlock Text="Red"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

            <Button Width="50"
                        Height="50"
                        Margin="20"
                        HorizontalAlignment="Center">

                <StackPanel>
                    <Rectangle Width="25"
                                   Height="25"
                                   Fill="Green"/>

                    <TextBlock Text="Red"
                                   HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Width="50"
                    Height="50"
                    Margin="20"
                    HorizontalAlignment="Center">

                <StackPanel>
                    <Rectangle Width="25"
                               Height="25"
                               Fill="Blue"/>

                    <TextBlock Text="Red"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>

        </StackPanel>

        <Button DockPanel.Dock ="Bottom"
                Margin="20"
                MinWidth="400"
                Height="230"
                Background="AliceBlue">Click to Close!</Button>

    </DockPanel>
</Window>