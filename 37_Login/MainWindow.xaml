<Window x:Class="_37_Login.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_37_Login"
        mc:Ignorable="d"
        Title="Login" Height="400" Width="500">
    <Grid Background="LightSteelBlue">
        <StackPanel Margin="50"
                    Background="AliceBlue">
            <!--1층-->
            <TextBlock Text="로그인"
                       HorizontalAlignment="Center"
                       FontSize="18"
                       FontWeight="Bold"
                       Padding="10"/>
            <!--2층-->
            <StackPanel Orientation="Horizontal"
                        Margin="20">
                <TextBlock Text="ID: "
                           FontSize="18"
                           Width="100"
                           HorizontalAlignment="Right"/>
                <TextBlock x:Name="txtID"
                           FontSize="18"
                           Width="200"/>
            </StackPanel>
            
            <!--3층-->
            <StackPanel Orientation="Horizontal"
                        Margin="20">
                <TextBlock Text="PW: "
                           FontSize="18"
                           Width="100"
                           HorizontalAlignment="Right"/>
                <TextBlock x:Name="txtPass"
                           FontSize="18"
                           Width="200"/>
            </StackPanel>
            
            <!--4층-->
            <StackPanel Orientation="Horizontal"
                        Margin="20">
                <TextBlock Text=""
                           FontSize="18"
                           Width="80"
                           HorizontalAlignment="Right"/>
                <Button Content="로그인"
                        FontSize="18"
                        Padding="10"
                        Width="200"
                        Click="Button_Click"/>
                <TextBlock Text=""
                           FontSize="18"
                           Width="80"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
