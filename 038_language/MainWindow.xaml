<Window x:Class="_038_language.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_038_language"
        mc:Ignorable="d"
        Title="Language" Height="350" Width="400"
        Background="LightSteelBlue">
    
    <StackPanel Margin="20"
                Background="AliceBlue">
        
        <!--<TextBlock HorizontalAlignment="Center">■ 좋아하는 언어는?</TextBlock>-->
        
        <TextBlock Text="■ 좋아하는 언어는?"
                   Margin="20 20 20 10"
                   FontSize="14"
                   HorizontalAlignment="Center"/>

        <Separator Margin="20 5 20 10"/>

        <CheckBox x:Name="cbC"
                  Content="C"
                  Margin="30 5 0 5"/>

        <CheckBox x:Name="cbCPP"
                  Content="C++"
                  Margin="30 5 0 5"/>

        <CheckBox x:Name="cbCS"
                  Content="C#"
                  Margin="30 5 0 5"/>

        <CheckBox x:Name="cbPython"
                  Content="Python"
                  Margin="30 5 0 5"/>

        <CheckBox x:Name="cbJava"
                  Content="Java"
                  Margin="30 5 0 5"/>

        <Separator Margin="20 5 20 10"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center">

            <Button x:Name="btnSubmit"
                    Content="투표하기"
                    Width="80"
                    Margin="0 5 20 0"
                    Padding="7" Click="btnSubmit_Click"/>

            <Button x:Name="btnExit"
                    Content="끝내기"
                    Width="80"
                    Margin="0 5 20 0"
                    Padding="7" Click="btnExit_Click"/>
        </StackPanel>

    </StackPanel>
</Window>